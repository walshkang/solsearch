# Google Maps JavaScript API key — enable Maps JS API + Places API (New) in GCP console
VITE_GOOGLE_MAPS_API_KEY=

# Google Maps Map ID — create one at console.cloud.google.com/google/maps-apis/studio/maps
VITE_GOOGLE_MAP_ID=

# MapTiler API key — used for MVT building tiles (maptiler.com/cloud)
VITE_MAPTILER_KEY=

# Google Gemini API key — enable Generative Language API in GCP or get from aistudio.google.com
VITE_GEMINI_API_KEY=
